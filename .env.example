# SQLAlchemy connection string for the local PostGIS database.
# Windows example with PostgreSQL on the default port 5432:
GEOMARKETING_DB_URL=postgresql+psycopg2://postgres@localhost:5432/geomarketing

# If you use Postgres.app on Mac, your local database may run on port 5433:
# GEOMARKETING_DB_URL=postgresql+psycopg2://postgres@localhost:5433/geomarketing
